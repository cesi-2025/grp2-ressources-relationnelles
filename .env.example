# Docker / Compose
COMPOSE_PROJECT_NAME=rr

# Database
POSTGRES_DB=ressources_relationnelles
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DB_PORT=5432
DB_HOST=db

# API
API_PORT=8000
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
DB_CONNECTION=pgsql
DB_DATABASE=ressources_relationnelles
DB_USERNAME=postgres
DB_PASSWORD=postgres

# CORS (web + mobile)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:19006,http://127.0.0.1:19006,http://localhost:8081,http://127.0.0.1:8081,exp://127.0.0.1:19000,exp://localhost:19000

# Database admin tool (Adminer)
DB_ADMIN_PORT=8080
