# Env vars to configure in Coolify for docker-compose.prod.yml
# (set these in the Coolify UI, not by committing a real .env file)

# Database
POSTGRES_DB=ressources_relationnelles
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

# API
# Generate once locally with: php artisan key:generate --show
# Never regenerate on the server - rotating this breaks any existing
# encrypted/signed data (cookies, tokens) on every restart.
APP_KEY=base64:change-me
APP_URL=https://api.yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Web
# Baked into the client bundle at build time - must be the public API URL.
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
